<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="20260707-01" author="mehmet">

        <createTable tableName="shipment">
            <column name="id" type="varchar(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tracking_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="sender_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="sender_address" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="receiver_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="receiver_address" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="assigned_courier_id" type="BIGINT"/> <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="shipment_status_history">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_shipment_history"/>
            </column>
            <column name="shipment_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="changed_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="note" type="VARCHAR(255)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="shipment_status_history" baseColumnNames="shipment_id"
                                 constraintName="fk_history_shipment"
                                 referencedTableName="shipment" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>